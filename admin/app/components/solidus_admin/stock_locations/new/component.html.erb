<%= page do %>
  <%= page_header do %>
    <%= page_header_back(back_url) %>
    <%= page_header_title(@stock_location.name) %>
    <%= page_header_actions do %>
      <%= render component("ui/button").discard(form: form_id) %>
      <%= render component("ui/button").save(form: form_id) %>
    <% end %>
  <% end %>

  <%= form_for @stock_location, url: form_url, html: { id: form_id } do |f| %>
    <%= page_with_sidebar do %>
      <%= page_with_sidebar_main do %>
        <%= render component('ui/panel').new do %>
          <%= render component("ui/forms/field").text_field(f, :name) %>
          <%= render component("ui/forms/field").text_field(f, :admin_name) %>
          <%= render component("ui/forms/field").text_area(f, :code) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= page_footer do %>
    <%= render component("ui/button").save(form: form_id) %>
  <% end %>
<% end %>
