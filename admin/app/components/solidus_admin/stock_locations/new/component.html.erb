<%= page do %>
  <%= page_header do %>
    <%= page_header_back(back_url) %>
    <%= page_header_title(@stock_location.name) %>
    <%= page_header_actions do %>
      <%= render component("ui/button").discard(form: form_id) %>
      <%= render component("ui/button").save(form: form_id) %>
    <% end %>
  <% end %>

  <%= form_for @stock_location, url: form_url, data: { turbo: false }, html: { id: form_id } do |f| %>
    <%= page_with_sidebar do %>
      <%= page_with_sidebar_main do %>
        <%= render component('ui/panel').new do %>
          <%= render component("ui/forms/field").text_field(f, :name, class: "required") %>
          <%= render component("ui/forms/field").text_field(f, :admin_name) %>
          <%= render component("ui/forms/field").text_field(f, :code) %>
        <% end %>

        <%= render component('ui/panel').new(title: t('.address')) do %>
          <%= render component("ui/forms/field").text_field(f, :address1) %>
          <%= render component("ui/forms/field").text_field(f, :address2) %>
          <%= render component("ui/forms/field").text_field(f, :city) %>
          <%= render component("ui/forms/field").text_field(f, :zipcode) %>
          <%#= render component("ui/forms/field").select(
            f,
            :country_id
          ) %>
        <% end %>

      <% end %>
    <% end %>
  <% end %>

  <%= page_footer do %>
    <%= render component("ui/button").save(form: form_id) %>
  <% end %>
<% end %>
